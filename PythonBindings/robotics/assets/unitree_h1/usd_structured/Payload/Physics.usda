                            uniform int mjc:group = 3
                            float newton:contactGap = 0
                            float physics:mass = 0
                        }

                        def PhysicsRevoluteJoint "right_shoulder_roll" (
                            prepend apiSchemas = ["MjcJointAPI"]
                        )
                        {
                            uniform double mjc:armature = 0.1
                            uniform double mjc:damping = 1
                            uniform token physics:axis = "X"
                            rel physics:body0 = </h1/Geometry/pelvis/torso_link/right_shoulder_pitch_link>
                            rel physics:body1 = </h1/Geometry/pelvis/torso_link/right_shoulder_pitch_link/right_shoulder_roll_link>
                            point3f physics:localPos0 = (-0.0055, -0.0565, -0.0165)
                            point3f physics:localPos1 = (0, 0, 0)
                            quatf physics:localRot0 = (0.97629637, 0.216438, 0, 0)
                            quatf physics:localRot1 = (1, 0, 0, 0)
                            float physics:lowerLimit = -178.18988
                            float physics:upperLimit = 19.480564
                        }

                        def "right_shoulder_yaw_link" (
                            prepend apiSchemas = ["PhysicsRigidBodyAPI", "PhysicsMassAPI"]
                        )
                        {
                            point3f physics:centerOfMass = (0.01365, -0.002767, -0.16266)
                            float3 physics:diagonalInertia = (0.00408038, 0.00370367, 0.000622687)
                            float physics:mass = 0.839
                            quatf physics:principalAxes = (0.7087978, -0.047336187, -0.033122893, 0.7030418)

                            over "right_shoulder_yaw_link" (
                                prepend apiSchemas = ["PhysicsCollisionAPI", "NewtonCollisionAPI", "MjcCollisionAPI", "PhysicsMeshCollisionAPI", "NewtonMeshCollisionAPI", "PhysicsMassAPI", "MaterialBindingAPI"]
                            )
                            {
                                rel material:binding:physics = </h1/Physics/PhysicsMaterial>
                                uniform int mjc:group = 2
                                float newton:contactGap = 0
                                uniform token physics:approximation = "convexHull"
                                bool physics:collisionEnabled = 0
                                float physics:density = 1000
                            }

                            over "Capsule" (
                                prepend apiSchemas = ["PhysicsCollisionAPI", "NewtonCollisionAPI", "MjcCollisionAPI", "PhysicsMassAPI", "MaterialBindingAPI"]
                            )
                            {
                                rel material:binding:physics = </h1/Physics/PhysicsMaterial>
                                uniform int mjc:group = 3
                                float newton:contactGap = 0
                                float physics:mass = 0
                            }

                            def PhysicsRevoluteJoint "right_shoulder_yaw" (
                                prepend apiSchemas = ["MjcJointAPI"]
                            )
                            {
                                uniform double mjc:armature = 0.1
                                uniform double mjc:damping = 1
                                uniform token physics:axis = "Z"
                                rel physics:body0 = </h1/Geometry/pelvis/torso_link/right_shoulder_pitch_link/right_shoulder_roll_link>
                                rel physics:body1 = </h1/Geometry/pelvis/torso_link/right_shoulder_pitch_link/right_shoulder_roll_link/right_shoulder_yaw_link>
                                point3f physics:localPos0 = (0, 0, -0.1343)
                                point3f physics:localPos1 = (0, 0, 0)
                                quatf physics:localRot0 = (1, 0, 0, 0)
                                quatf physics:localRot1 = (1, 0, 0, 0)
                                float physics:lowerLimit = -254.96622
                                float physics:upperLimit = 74.48451
                            }

                            def "right_elbow_link" (
                                prepend apiSchemas = ["PhysicsRigidBodyAPI", "PhysicsMassAPI"]
                            )
                            {
                                point3f physics:centerOfMass = (0.15908, 0.000144, -0.015776)
                                float3 physics:diagonalInertia = (0.00601829, 0.00600579, 0.000408305)
                                float physics:mass = 0.669
                                quatf physics:principalAxes = (-0.076523185, 0.72032684, -0.08531158, 0.6841018)

                                over "right_elbow_link" (
                                    prepend apiSchemas = ["PhysicsCollisionAPI", "NewtonCollisionAPI", "MjcCollisionAPI", "PhysicsMeshCollisionAPI", "NewtonMeshCollisionAPI", "PhysicsMassAPI", "MaterialBindingAPI"]
                                )
                                {
                                    rel material:binding:physics = </h1/Physics/PhysicsMaterial>
                                    uniform int mjc:group = 2
                                    float newton:contactGap = 0
                                    uniform token physics:approximation = "convexHull"
                                    bool physics:collisionEnabled = 0
                                    float physics:density = 1000
                                }

                                over "Capsule" (
                                    prepend apiSchemas = ["PhysicsCollisionAPI", "NewtonCollisionAPI", "MjcCollisionAPI", "PhysicsMassAPI", "MaterialBindingAPI"]
                                )
                                {
                                    rel material:binding:physics = </h1/Physics/PhysicsMaterial>
                                    uniform int mjc:group = 3
                                    float newton:contactGap = 0
                                    float physics:mass = 0
                                }

                                over "Sphere" (
                                    prepend apiSchemas = ["PhysicsCollisionAPI", "NewtonCollisionAPI", "MjcCollisionAPI", "PhysicsMassAPI", "MaterialBindingAPI"]
                                )
                                {
                                    rel material:binding:physics = </h1/Physics/PhysicsMaterial>
                                    uniform int mjc:group = 3
                                    float newton:contactGap = 0
                                    float physics:mass = 0
                                }

                                def PhysicsRevoluteJoint "right_elbow" (
                                    prepend apiSchemas = ["MjcJointAPI"]
                                )
                                {
                                    uniform double mjc:armature = 0.1
                                    uniform double mjc:damping = 1
                                    uniform token physics:axis = "Y"
                                    rel physics:body0 = </h1/Geometry/pelvis/torso_link/right_shoulder_pitch_link/right_shoulder_roll_link/right_shoulder_yaw_link>
                                    rel physics:body1 = </h1/Geometry/pelvis/torso_link/right_shoulder_pitch_link/right_shoulder_roll_link/right_shoulder_yaw_link/right_elbow_link>
                                    point3f physics:localPos0 = (0.0185, 0, -0.198)
                                    point3f physics:localPos1 = (0, 0, 0)
                                    quatf physics:localRot0 = (1, 0, 0, 0)
                                    quatf physics:localRot1 = (1, 0, 0, 0)
                                    float physics:lowerLimit = -71.61973
                                    float physics:upperLimit = 149.54198
                                }
                            }
                        }
                    }
                }
            }
        }
    }
}

def PhysicsScene "PhysicsScene" (
    prepend apiSchemas = ["NewtonSceneAPI", "MjcSceneAPI"]
)
{
    uniform token mjc:compiler:angle = "radian"
    uniform int newton:maxSolverIterations = 100
    uniform int newton:timeStepsPerSecond = 500
    vector3f physics:gravityDirection = (0, 0, -1)
    float physics:gravityMagnitude = 9.81
}

